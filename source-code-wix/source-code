                                                            "title11": "<h5 class=\"font_5\"><strong>Fresh Seafood Stalls Inside the Fish Market<\/strong><\/h5>",
                                                            "detail212": "<h5 class=\"font_5\"><strong>Outdoor fish market area<\/strong><\/h5>",
                                                            "nh1": "wix:image:\/\/v1\/f6985b_7a76983d059744449fa506f87d3baeb6~mv2.webp\/hinh-3-1699588172567482529305.webp#originWidth=640&originHeight=426",
